module LDP_DDS {
  @final
  enum PacketKind {
    LDP_DDS_PACKET_DATA,
    LDP_DDS_PACKET_CONTROL,
    LDP_DDS_PACKET_FAULT
  };

  @final
  struct Packet {
    unsigned long source_entity;
    unsigned long target_entity;
    unsigned long interface_id;
    unsigned long wire_id;
    unsigned long source_port;
    unsigned long target_port;
    unsigned short module_id;
    unsigned short msg_id;
    PacketKind kind;
    sequence<octet> payload;
  };
};
